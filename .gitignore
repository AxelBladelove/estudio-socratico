# Ejecutables compilados
*.exe
*.out
a.out
*.pdf
.pdf
!adjuntar/*.pdf
!adjuntar/**/*.pdf

# Objetos
*.o
*.obj

# Archivos temporales de editores
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Archivos temporales del compilador (no son telemetria)
gcc_err.txt
gcc_err2.txt
gcc_exit.txt
gcc_test.txt
_tmp_*.c
_tmp_*.txt

# Identidad local del clon (no se comparte)
.estudio_usuario

# Runtime local generado por el wrapper de compilacion
soporte/runtime/
.output/
logs/setup/

# Extension local de VS Code generada por setup
soporte/vscode/**/node_modules/
soporte/vscode/**/*.vsix
soporte/runtime/vscode/

# Configuracion local de APIs auxiliares (nunca guardar tokens)
.estudio_exercism.local.json
soporte/exercism/config.local.json
.estudio-drive/
**/.estudio-tests/
**/.estudio-drive/

# Artefactos locales de pruebas de agentes
.agent/*.exe
.agent/*.bmp
.agent/*_probe*.c
.agent/*_probe*.log
.agent/windows_console_launcher.*
.agent/start_windows_console_launcher.ps1

# NO rastrear estos (son estado interno de maquina, no telemetria):
logs/*/bloque_actual.txt
usuarios/*/logs/**/bloque_actual.txt

# SI rastrear estos cuando existan (son telemetria de estudio):
# usuarios/<usuario>/logs/<ejercicio>/bloqueN.log
# usuarios/<usuario>/errores.md
