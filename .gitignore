# Ejecutables compilados
*.exe
*.out
a.out
*.pdf
.pdf

# Objetos
*.o
*.obj

# Archivos temporales de editores
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Archivos temporales del compilador (no son telemetria)
gcc_err.txt
gcc_err2.txt
gcc_exit.txt
gcc_test.txt
_tmp_*.c
_tmp_*.txt

# Identidad local del clon (no se comparte)
.estudio_usuario

# Runtime local generado por el wrapper de compilacion
_estudio/soporte/runtime/
.output/
_estudio/logs/

# Extension local de VS Code generada por setup
_estudio/soporte/vscode/**/node_modules/
_estudio/soporte/vscode/**/*.vsix
_estudio/soporte/runtime/vscode/

# Configuracion local de APIs auxiliares (nunca guardar tokens)
.estudio_exercism.local.json
_estudio/soporte/exercism/config.local.json
.estudio-drive/
**/.estudio-tests/
**/.estudio-drive/

# Artefactos locales de pruebas de agentes
_estudio/.agent/*.exe
_estudio/.agent/*.bmp
_estudio/.agent/*_probe*.c
_estudio/.agent/*_probe*.log
_estudio/.agent/windows_console_launcher.*
_estudio/.agent/start_windows_console_launcher.ps1

# NO rastrear estos (son estado interno de maquina, no telemetria):
logs/*/bloque_actual.txt
usuario/logs/**/bloque_actual.txt
_estudio/usuarios/*/logs/**/bloque_actual.txt

# SI rastrear estos cuando existan (son telemetria de estudio):
# usuario/logs/<ejercicio>/bloqueN.log
# usuario/errores.md

# Extension and VSIX
*.vsix
_estudio/src/generated/
media/generated/
_estudio/soporte/vscode/estudio-exercism/generated/
.generated/gists/
*.private-manifest.json
*gist-state*.json
catalog.private.json

# Estudio Setup 2.0 local build artifacts
_estudio/setup/Estudio.Setup.exe
_estudio/setup/Estudio.Setup.pdb
_estudio/setup/Estudio.Setup/**/bin/
_estudio/setup/Estudio.Setup/**/obj/
_estudio/setup/Estudio.Setup/publish/
_estudio/setup/Estudio.Setup/.tmp-state/
_estudio/setup/textual/build/
_estudio/setup/textual/__pycache__/
_estudio/setup/textual/**/*.pyc

# Private/generated runtime config must never be committed.
runtime-config.private.json
runtime-config.bootstrap.json
gemini-key.local.json
app-config.generated.json
