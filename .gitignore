# Ejecutables compilados
*.exe
*.out
a.out
*.pdf
.pdf
!adjuntar/*.pdf
!adjuntar/**/*.pdf

# Objetos
*.o
*.obj

# Archivos temporales de editores
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Archivos temporales del compilador (no son telemetría)
gcc_err.txt
gcc_err2.txt
gcc_exit.txt
gcc_test.txt
_tmp_*.c
_tmp_*.txt

# Identidad local del clon (no se comparte)
.estudio_usuario

# Runtime local generado por el wrapper de compilacion
soporte/runtime/
.output/

# Artefactos locales de pruebas de agentes
.agent/*.exe
.agent/*.bmp
.agent/*_probe*.c
.agent/*_probe*.log
.agent/windows_console_launcher.*
.agent/start_windows_console_launcher.ps1

# NO rastrear estos (son estado interno de maquina, no telemetria):
logs/*/bloque_actual.txt
usuarios/*/logs/**/bloque_actual.txt

# SÍ rastrear estos (son la telemetría del sistema):
# logs/<ejercicio>/bloqueN.log  → un log por bloque de 45 min por ejercicio
# errores.md                    → base de conocimiento acumulativa
# usuarios/<usuario>/logs/<ejercicio>/bloqueN.log  → telemetría personal por usuario
# usuarios/<usuario>/errores.md                    → base de conocimiento por usuario
