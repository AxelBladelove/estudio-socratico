<Window x:Class="Estudio.Setup.WindowsHost.GuidedSolutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Solución guiada"
        Width="720"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F1E8">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Solution.Title}" FontSize="28" FontWeight="SemiBold" Foreground="#1C2B23" TextWrapping="Wrap" />
            <TextBlock Margin="0,12,0,0" Text="{Binding Solution.Summary}" FontSize="16" Foreground="#4D5A53" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,24,0,24" Background="White" CornerRadius="20" Padding="22">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Solution.Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" Background="#F7F3EC" CornerRadius="14" Padding="16">
                                <TextBlock Text="{Binding}" FontSize="16" Foreground="#1C2B23" TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button x:Name="ActionButton"
                    Content="{Binding Solution.ActionLabel}"
                    Width="180"
                    Height="44"
                    Margin="0,0,12,0"
                    Background="#2E6A4F"
                    Foreground="White"
                    BorderThickness="0"
                    Visibility="Collapsed"
                    DockPanel.Dock="Left" />
            <Button x:Name="CloseButton"
                    Content="Cerrar"
                    Width="140"
                    Height="44"
                    Background="#E7E1D6"
                    Foreground="#1C2B23"
                    BorderBrush="Transparent"
                    DockPanel.Dock="Right" />
        </DockPanel>
    </Grid>
</Window>