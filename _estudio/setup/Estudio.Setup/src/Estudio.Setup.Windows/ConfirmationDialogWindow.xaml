<Window x:Class="Estudio.Setup.WindowsHost.ConfirmationDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Estudio Socrático"
    Icon="Assets/estudio.png"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource PanelBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Border Margin="18"
            Padding="24"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Headline}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="24"
                       FontWeight="Bold"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="1"
                       Margin="0,14,0,0"
                       Text="{Binding Body}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="15"
                       LineHeight="22"
                       TextWrapping="Wrap" />

                <Grid Grid.Row="2" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="SecondaryButton"
                    Grid.Column="0"
                    Content="{Binding SecondaryButtonText}"
                    Height="42"
                    MinWidth="170"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="OnSecondaryButtonClick" />
                <Button x:Name="PrimaryButton"
                    Grid.Column="2"
                    Content="{Binding PrimaryButtonText}"
                    Height="42"
                    MinWidth="170"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnPrimaryButtonClick" />
                </Grid>
        </Grid>
    </Border>
</Window>