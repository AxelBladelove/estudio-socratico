<Window x:Class="Estudio.Setup.WindowsHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Instalar Estudio Socrático"
        Width="1080"
        Height="720"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        Icon="Assets/estudio.png"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="352" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="60"
                                Height="60"
                                CornerRadius="16"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrushStrong}"
                                BorderThickness="1">
                            <Grid>
                                <Image Source="Assets/estudio.png"
                                       Width="32"
                                       Height="36"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Estudio Socrático"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Instalador para VS Code"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="14"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Margin="0,16,0,0"
                               Text="Tu espacio de estudio quedará listo con GitHub, Exercism y F9 dentro de VS Code."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="15"
                               LineHeight="22"
                               TextWrapping="Wrap" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,24,0,24"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <ItemsControl ItemsSource="{Binding NavigationSteps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="StepCard"
                                        Margin="0,0,0,12"
                                        Padding="14"
                                        CornerRadius="14"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="StepBadge"
                                                Width="34"
                                                Height="34"
                                                CornerRadius="17"
                                                Background="{StaticResource CardBackgroundBrush}"
                                                BorderBrush="{StaticResource BorderBrushStrong}"
                                                BorderThickness="1">
                                            <TextBlock x:Name="StepBadgeText"
                                                       Text="{Binding StatusGlyph}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock x:Name="StepTitle"
                                                       Text="{Binding Title}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock x:Name="StepDescription"
                                                       Text="{Binding Description}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="13"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter TargetName="StepCard" Property="Background" Value="{StaticResource SuccessSurfaceBrush}" />
                                        <Setter TargetName="StepCard" Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                                        <Setter TargetName="StepBadge" Property="Background" Value="{StaticResource SuccessBrush}" />
                                        <Setter TargetName="StepBadge" Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                                        <Setter TargetName="StepBadgeText" Property="Foreground" Value="{StaticResource WindowBackgroundBrush}" />
                                        <Setter TargetName="StepTitle" Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="StepCard" Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                                        <Setter TargetName="StepCard" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="StepBadge" Property="Background" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="StepBadge" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="StepBadgeText" Property="Foreground" Value="White" />
                                        <Setter TargetName="StepTitle" Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="2"
                           Text="Tu carpeta de estudio quedará fuera del ZIP y lista para abrirse en VS Code."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           LineHeight="18" />
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="StatusHeadlineText"
                               Text="{Binding StatusHeadline}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="32"
                               FontWeight="Bold"
                               LineHeight="42"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <TextBlock x:Name="StatusBodyText"
                               Text="{Binding StatusBody}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="16"
                               LineHeight="24"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,28,0,24">
                    <Grid.Resources>
                        <Style x:Key="ScreenViewerStyle" TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
                            <Setter Property="Focusable" Value="False" />
                        </Style>

                        <Style x:Key="ScreenCardStyle" TargetType="Border">
                            <Setter Property="CornerRadius" Value="16" />
                            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="24" />
                        </Style>
                    </Grid.Resources>

                    <ScrollViewer>
                        <ScrollViewer.Style>
                            <Style BasedOn="{StaticResource ScreenViewerStyle}" TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWelcomeScreen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel Margin="0,0,8,0">
                            <Border Style="{StaticResource ScreenCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Carpeta de trabajo"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="15" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding InstallationFolder}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="16"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Puedes cambiarla ahora si prefieres otra ubicación antes de empezar."
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="14"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="InitialErrorPanel"
                                    Visibility="Collapsed"
                                    Background="{StaticResource ErrorSurfaceBrush}"
                                    BorderBrush="{StaticResource ErrorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16"
                                    Margin="0,18,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="InitialErrorHeadlineText"
                                               Text="No pude continuar con la revisión inicial."
                                               Foreground="{StaticResource ErrorBrush}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="InitialErrorBodyText"
                                               Margin="0,10,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                    <Expander x:Name="InitialErrorDetailsExpander" Header="Ver detalles técnicos" Margin="0,14,0,0">
                                        <Border Padding="14"
                                                Background="{StaticResource CardBackgroundBrush}"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                                <TextBlock x:Name="InitialErrorDetailsText"
                                                           TextWrapping="Wrap"
                                                           FontFamily="Consolas"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </ScrollViewer>
                                        </Border>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer>
                        <ScrollViewer.Style>
                            <Style BasedOn="{StaticResource ScreenViewerStyle}" TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsQuickReviewScreen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel Margin="0,0,8,0">
                            <ItemsControl ItemsSource="{Binding QuickChecks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="QuickCheckCard"
                                                Margin="0,0,0,12"
                                                Padding="18"
                                                Background="{StaticResource CardBackgroundBrush}"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="QuickCheckBadge"
                                                        Width="38"
                                                        Height="38"
                                                        CornerRadius="19"
                                                        Background="{StaticResource WarningSurfaceBrush}"
                                                        BorderBrush="{StaticResource WarningBrush}"
                                                        BorderThickness="1">
                                                    <TextBlock x:Name="QuickCheckGlyph"
                                                               Text="{Binding StatusGlyph, Mode=OneWay}"
                                                               Foreground="{StaticResource WarningBrush}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Title, Mode=OneWay}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="18"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Message, Mode=OneWay}"
                                                               Margin="0,8,0,0"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="15"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsReady}" Value="True">
                                                <Setter TargetName="QuickCheckBadge" Property="Background" Value="{StaticResource SuccessSurfaceBrush}" />
                                                <Setter TargetName="QuickCheckBadge" Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                                                <Setter TargetName="QuickCheckGlyph" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer>
                        <ScrollViewer.Style>
                            <Style BasedOn="{StaticResource ScreenViewerStyle}" TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAccountsScreen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel Margin="0,0,8,0">
                            <Border Style="{StaticResource ScreenCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding GitHubCardTitle}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="22"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding GitHubCardSubtitle}"
                                               Margin="0,10,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding GitHubStatus}"
                                               Margin="0,10,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button x:Name="OpenGitHubButton"
                                                Content="{Binding GitHubPrimaryActionText}"
                                                IsEnabled="{Binding IsGitHubPrimaryActionEnabled}"
                                                Width="180"
                                                Height="42"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button x:Name="ChangeGitHubAccountButton"
                                                Content="Cambiar cuenta"
                                                Width="180"
                                                Height="42"
                                                Margin="12,0,0,0">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource SecondaryButtonStyle}" TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowGitHubChangeAccount}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>

                                    <Border Margin="0,16,0,0"
                                            Background="{StaticResource ErrorSurfaceBrush}"
                                            BorderBrush="{StaticResource ErrorBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="16">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasGitHubActionError}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding GitHubActionErrorHeadline}"
                                                       Foreground="{StaticResource ErrorBrush}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding GitHubActionErrorBody}"
                                                       Margin="0,10,0,0"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                <Button x:Name="RetryGitHubActionButton"
                                                        Content="Reintentar"
                                                        Width="130"
                                                        Height="40"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </StackPanel>
                                            <Expander Header="Ver detalles técnicos" Margin="0,14,0,0">
                                                <Border Padding="14"
                                                        Background="{StaticResource CardBackgroundBrush}"
                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding GitHubActionErrorTechnicalDetails}"
                                                                   FontFamily="Consolas"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </ScrollViewer>
                                                </Border>
                                            </Expander>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ScreenCardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding ExercismCardTitle}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="22"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ExercismCardSubtitle}"
                                               Margin="0,10,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />

                                    <Button x:Name="OpenExercismButton"
                                            Content="{Binding ExercismPrimaryActionText}"
                                            Width="220"
                                            Height="42"
                                            Margin="0,16,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}" />

                                    <StackPanel Margin="0,16,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowExercismTokenInput}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Token de Exercism"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="15" />
                                        <TextBox x:Name="ExercismTokenTextBox"
                                                 Margin="0,8,0,0"
                                                 Height="42"
                                                 Text="{Binding ExercismToken, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding ExercismStatus}"
                                               Margin="0,12,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16">
                                <TextBlock Text="{Binding AccountsReadinessMessage}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer>
                        <ScrollViewer.Style>
                            <Style BasedOn="{StaticResource ScreenViewerStyle}" TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPreparingScreen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel Margin="0,0,8,0">
                            <ItemsControl ItemsSource="{Binding ProgressBlocks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="18"
                                                Background="{StaticResource CardBackgroundBrush}"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               DockPanel.Dock="Left" />
                                                    <TextBlock x:Name="ProgressStatusText"
                                                               Text="{Binding StatusLabel}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontWeight="SemiBold"
                                                               DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding HumanMessage}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="15"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding StatusLabel}" Value="Listo">
                                                <Setter TargetName="ProgressStatusText" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusLabel}" Value="Completado">
                                                <Setter TargetName="ProgressStatusText" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusLabel}" Value="Reparado">
                                                <Setter TargetName="ProgressStatusText" Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusLabel}" Value="Atencion">
                                                <Setter TargetName="ProgressStatusText" Property="Foreground" Value="{StaticResource WarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusLabel}" Value="Error">
                                                <Setter TargetName="ProgressStatusText" Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Expander Header="Ver detalles técnicos" IsExpanded="{Binding ShowTechnicalDetails}" Margin="0,12,0,0">
                                <Border Padding="14"
                                        Background="{StaticResource CardBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding TechnicalDetails}"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer>
                        <ScrollViewer.Style>
                            <Style BasedOn="{StaticResource ScreenViewerStyle}" TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFinishedScreen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel Margin="0,0,8,0">
                            <Border Style="{StaticResource ScreenCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Todo está listo."
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="28"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,14,0,0"
                                               Text="Puedes empezar con F9 dentro de VS Code."
                                               FontSize="16"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <Border Margin="0,24,0,0"
                                            Background="{StaticResource CardSoftBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Carpeta abierta al terminar"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding InstallationFolder}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="16"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Expander Header="Ver detalles técnicos" IsExpanded="{Binding ShowTechnicalDetails}" Margin="0,16,0,0">
                                <Border Padding="14"
                                        Background="{StaticResource CardBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding TechnicalDetails}"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <DockPanel Grid.Row="2" LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button x:Name="ChangeFolderButton"
                                Content="Cambiar carpeta"
                                Width="180"
                                Height="42"
                                Margin="0,0,12,0"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button x:Name="RetryButton"
                                Content="Reintentar"
                                Width="120"
                                Height="42"
                                Margin="0,0,12,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Visibility="Collapsed" />
                        <Button x:Name="GuidedHelpButton"
                                Content="Ver solución guiada"
                                Width="170"
                                Height="42"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="Collapsed" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button x:Name="PrimaryButton"
