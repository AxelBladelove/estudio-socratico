{
  "name": "estudio-exercism",
  "displayName": "Estudio Socratico - Exercism",
  "description": "Panel de ejercicios para Exercism C y PDF Alejandro Liz dentro de Estudio Socratico.",
  "version": "2.0.0",
  "publisher": "estudio-socratico",
  "license": "MIT",
  "icon": "assets/estudio.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onView:estudioExercism.view",
    "onCommand:estudioExercism.openPanel",
    "onCommand:estudioExercism.openApiKeyConfig",
    "onCommand:estudioExercism.revealApiKeyConfig",
    "onUri"
  ],
  "categories": [
    "Education",
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "estudioSocratico",
          "title": "Estudio",
          "icon": "assets/estudio.svg"
        }
      ]
    },
    "views": {
      "estudioSocratico": [
        {
          "type": "webview",
          "id": "estudioExercism.view",
          "name": "Ejercicios",
          "icon": "assets/estudio.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "estudioExercism.openPanel",
        "title": "Estudio Socratico: Abrir Panel de Ejercicios"
      },
      {
        "command": "estudioExercism.testCurrent",
        "title": "Estudio Socratico: Probar Ejercicio Actual"
      },
      {
        "command": "estudioExercism.submitCurrent",
        "title": "Estudio Socratico: Enviar Ejercicio Actual"
      },
      {
        "command": "estudioExercism.validateCurrent",
        "title": "Estudio Socratico: Validar Ejercicio Actual"
      },
      {
        "command": "estudioExercism.openApiKeyConfig",
        "title": "Estudio Socratico: Abrir Configuración de API Key"
      },
      {
        "command": "estudioExercism.revealApiKeyConfig",
        "title": "Estudio Socratico: Revelar Configuración de API Key en Explorador"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "estudioExercism.openPanel",
          "when": "resourceLangId == c",
          "group": "navigation@98"
        },
        {
          "command": "estudioExercism.testCurrent",
          "when": "resourceLangId == c",
          "group": "navigation@99"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.15.0"
  }
}
