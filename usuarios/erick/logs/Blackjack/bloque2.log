#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <conio.h>

#define MAXCARTAS 52
#define MAXCARTAREP 11

int randrange(int liminf, int limsup);
int simbolocarta(int indice);
int valorcarta(int indice);
int tomarcarta(int mazo[ ]);
void showcart_xy(int indice, int px, int py);
int sumacarta(int cartas[ ], int n);



int main()
{
   srand(time(NULL));
   for (int ascii = 1 ascii <= 255; ascii++)
   {
      printf("%d %c\n\n", ascii, ascii);
   }


   int mazo[MAXCARTAS] = {0};
   int jugador[MAXCARTAREP];
   int computadora[MAXCARTAREP];
return 0;    
}
/*que dado un indice, retorna: 0 si el sГӯmbolo correspondiente segГәn
el Гӯndice del arreglo es un corazГіn, 1 si el sГӯmbolo correspondiente segГәn el Гӯndice del arreglo es
un diamante, 2 si el sГӯmbolo correspondiente segГәn el Гӯndice del arreglo es un trГ©bol y 3 si el
sГӯmbolo correspondiente segГәn el Гӯndice del arreglo es una espada (o pique).*/
int simbolocarta(int indice){
    
   return indice % 4; 
}







int valorcarta(int indice)
{      
   return (indice / 4) + 1;
}

int tomarcarta (int mazo[])
{
   int indice;
   do{
      indice = randrange(0, MAXCARTAS - 1);
   }while (mazo[indice]);
   mazo[indice] = 1;
   return indice;
}





int randrange(int liminf, int limsup)
{
   return rand() % (limsup - liminf + 1) + liminf;
}





void showcart_xy(int indice, int px, int py)
{
   gotoxy(px,py);
}
 
