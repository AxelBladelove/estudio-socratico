#include <conio.h>

#define MAXCARTAS 52
#define MAXCARTAREP 11
#define ESI 218
#define ESD 191
#define LH 196
#define EII 192
#define EID 217
#define LV 179


int randrange(int liminf, int limsup);
int simbolocarta(int indice);
int valorcarta(int indice);
int tomarcarta(int mazo[ ]);
void showcart_xy(int indice, int px, int py);
