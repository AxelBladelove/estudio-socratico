int main()
{
   srand(time(NULL));

   int mazo[MAXCARTAS] = {0};
   int jugador[MAXCARTAREP];
   int computadora[MAXCARTAREP];


   return 0;    
}

int simbolocarta(int indice){
    
   return indice % 4; 
}

