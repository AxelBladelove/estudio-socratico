#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <conio.h>

#define VALINI  0
#define CT      GREEN
#define CF      YELLOW
#define CSEL    WHITE
#define MINVAL       3
#define MAXVAL      15
#define MOVIMIENTO   1

#define ENTER     13
#define ESC       27
#define ARRIBA    72
#define ABAJO     80
#define DERECHA   77
#define IZQUIERDA 75
#define ESP       32

void setcolor(int ct, int cf);
void colordefault(void);
int maxval(int fil, int col, int mat[fil][col]);
int randrange(int liminf, int limsup);
void initcuadro(int dim, int cuadro[dim][dim],int valini);
void gencuadro(int dim, int cuadro[dim][dim]);
int existe(int fils, int cols,int mat[fils][cols],int val);
void showcuadro(int dim, int cuadro[dim][dim],int posx, int posy);
void movecuadro(int dim, int cuadro[dim][dim],int posx, int posy);
int ordenado(int dim, int cuadro[dim][dim]);
void ordenar(int dim, int cuadro[dim][dim]);
void clearxy(int posx, int posy,int ancho,int largo);

int main()
{
   srand(time(NULL));

   int dim;

   do{
      printf("Dimensi%cn: ",162);
      scanf("%d",&dim);
      if ( dim < MINVAL || dim > MAXVAL )
         printf("Dimensi%cn debe estar entre %d y %d\n",162,MINVAL,MAXVAL);
   }while ( dim < MINVAL || dim > MAXVAL );

   int cuadro[dim][dim];

   gencuadro(dim,cuadro);
   movecuadro(dim,cuadro,10,5);

   return 0;
}

int randrange(int liminf, int limsup)
{
   return rand() % (limsup - liminf + 1) + liminf;
}

void initcuadro(int dim, int cuadro[dim][dim],int valini)
{
   for (int indfil = 0;  indfil < dim; indfil++ )
      for (int indcol = 0; indcol < dim; indcol++ )
         cuadro[indfil][indcol] = valini;
   return;
}

void gencuadro(int dim, int cuadro[dim][dim])
{
   int val;
   initcuadro(dim,cuadro,VALINI);
   for (int indfil = 0;  indfil < dim; indfil++ )
      for (int indcol = 0; indcol < dim; indcol++ )
         if ( !(indfil == dim-1 && indcol == dim-1) )
         {
            do{
               val = randrange(1,(dim*dim-1));
            }while ( existe(dim,dim,cuadro,val) );
            cuadro[indfil][indcol] = val;
         }
}
int existe(int fils, int cols, int mat[fils][cols],int val)
{
   for (int indfil = 0;  indfil < fils; indfil++ )
      for (int indcol = 0; indcol < cols; indcol++ )
         if ( mat[indfil][indcol] == val )
            return 1;
   return 0;
}
void movecuadro(int dim, int cuadro[dim][dim],int posx, int posy)
{
   int filsel = dim-1, colsel = dim-1;
   int cantdigvalmax = (int)log10(maxval(dim,dim,cuadro)) + 1;
   int modo = MOVIMIENTO;
   char tecla;
   _setcursortype(0);
   do{
      showcuadro(dim,cuadro,posx,posy);
      do{
         tecla = getch();
      }while (tecla != ENTER && tecla != ARRIBA && tecla != ABAJO &&
              tecla != DERECHA && tecla != IZQUIERDA && tecla != ESC
              && tecla != ESP);

      if (tecla == ESP)
         modo = !modo;

      if ( tecla == IZQUIERDA  )
         if ( modo == MOVIMIENTO )
         {
            if ( colsel > 0 )
            {
               cuadro[filsel][colsel] = cuadro[filsel][colsel-1];
               cuadro[filsel][colsel-1] = VALINI;
               colsel--;
            }
         }
         else
         {
            setcolor(BLACK,BLACK);
            clearxy(posx+((dim-1)*(cantdigvalmax+1)),posy,(cantdigvalmax+1),dim);
            posx--;
         }


       if ( tecla == ARRIBA )
         if ( modo == MOVIMIENTO )
         {
            if ( filsel > 0 )
            {
               cuadro[filsel][colsel] = cuadro[filsel-1][colsel];
               cuadro[filsel-1][colsel] = VALINI;
               filsel--;
            }
         }
         else
         {
            setcolor(BLACK,BLACK);
            clearxy(posx,posy+dim-1,dim*(cantdigvalmax+1),1);
            posy--;
         }

      if ( tecla == DERECHA  )
         if ( modo == MOVIMIENTO )
         {
            if ( colsel < dim-1 )
            {
               cuadro[filsel][colsel] = cuadro[filsel][colsel+1];
               cuadro[filsel][colsel+1] = VALINI;
               colsel++;
            }
         }
         else
         {
            setcolor(BLACK,BLACK);
            clearxy(posx,posy,(cantdigvalmax+1),dim);
            posx++;
         }

       if ( tecla == ABAJO )
         if ( modo == MOVIMIENTO )
         {
            if ( filsel < dim - 1  )
            {
               cuadro[filsel][colsel] = cuadro[filsel+1][colsel];
               cuadro[filsel+1][colsel] = VALINI;
               filsel++;
            }
         }
         else
         {
            setcolor(BLACK,BLACK);
            clearxy(posx,posy,dim*(cantdigvalmax+1),1);
            posy++;
         }

      if ( tecla == ENTER  && modo == MOVIMIENTO)
         ordenar(dim,cuadro);

      if (modo == MOVIMIENTO && ordenado(dim,cuadro))
      {
         showcuadro(dim,cuadro,posx,posy);
         gotoxy(posx,posy+dim+2);
         printf("Muchas felicidades! Lo ordenaste!");
         tecla = ESC;
      }

   }while ( tecla != ESC );
   _setcursortype(100);
}
void showcuadro(int dim, int cuadro[dim][dim],int posx, int posy)
{
   int cantdigvalmax = (int)log10(maxval(dim,dim,cuadro)) + 1;
   for (int indfil = 0;  indfil < dim; indfil++ )
      for (int indcol = 0; indcol < dim; indcol++ )
      {
         setcolor(CT,CF);
         if ( cuadro[indfil][indcol] == VALINI )
            setcolor(CSEL,CSEL);
         gotoxy(posx+(indcol*(cantdigvalmax+1)),posy+indfil);
         printf("%*d ",cantdigvalmax,cuadro[indfil][indcol]);
      }
   colordefault();
}

int maxval(int fil, int col, int mat[fil][col])
{
   int valmax = mat[0][0];
   for (int indfil = 0; indfil < fil; indfil++ )
      for ( int indcol = 0; indcol < col; indcol++ )
         if ( valmax < mat[indfil][indcol] )
            valmax = mat[indfil][indcol];
   return valmax;
}

void setcolor(int ct, int cf)
{
   textbackground(cf);
   textcolor(ct);
}

void colordefault(void)
{
   setcolor(LIGHTGRAY,BLACK);
}

int ordenado(int dim, int cuadro[dim][dim])
{
   int ant = cuadro[0][0];
   for (int indfil = 0;  indfil < dim; indfil++ )
      for (int indcol = 0; indcol < dim; ant = cuadro[indfil][indcol],indcol++ )
         if ( !( indfil == dim-1 && indcol == dim-1 ))
            if ( ant > cuadro[indfil][indcol] )
               return 0;
   return 1;
}
void ordenar(int dim, int cuadro[dim][dim])
{
   int val = 1;
   for (int indfil = 0;  indfil < dim; indfil++ )
      for (int indcol = 0; indcol < dim; indcol++ )
         cuadro[indfil][indcol] = val++;
   cuadro[dim-1][dim-1] = VALINI;
}

void clearxy(int posx,int posy,int ancho,int largo)
{
   for ( int indfil = 0; indfil < largo; indfil++ )
      for ( int indcol = 0; indcol < ancho; indcol++ )
      {
         gotoxy(posx+indcol,posy+indfil);
         printf(" ");
      }
}
 
