Profesor: Alejandro Liz
Se utilizarĂĄ las siguientes funciones:
int simbolocarta(int indice), que dado un indice, retorna: 0 si el sĂ­mbolo correspondiente segĂșn
el Ă­ndice del arreglo es un corazĂłn, 1 si el sĂ­mbolo correspondiente segĂșn el Ă­ndice del arreglo es
un diamante, 2 si el sĂ­mbolo correspondiente segĂșn el Ă­ndice del arreglo es un trĂ©bol y 3 si el
sĂ­mbolo correspondiente segĂșn el Ă­ndice del arreglo es una espada (o pique).
int valorcarta(int indice), que retorna el valor de la carta de acuerdo al valor del Ă­ndice. Es decir,
los primeros 4 valores son los 1 o los ases (âAâ), los siguientes 4 son los 2âs, y asĂ­ sucesivamente
de tal forma que los Ășltimos 4 son los 13âs.
int tomarcarta(int mazo[ ]), que retorna, de forma aleatoria, el Ă­ndice de una carta disponible
para ârepartirâ asignando a la misma el valor de 1.
void showcart_xy(int indice, int px, int py), que imprime de forma grĂĄfica, en la posiciĂłn indicada
en âpxâ y âpyâ, la carta que se encuentra en el Ă­ndice âindiceâ [0,51].
int sumacarta(int cartas[ ], int n), que retorna la suma de ânâ cartas en el arreglo âcartasâ que
contiene los Ă­ndices de las cartas asignadas. AsĂ­,si se llama con las cartas contenidas en el arreglo
de cartas de jugador âjugadorâ o de la computadora âcomputadoraâ se tendrĂ­a el total de la
suma Ăłptima de las mismas. Es decir, que busque no pasarse de 21 puntos.
Se requiere:
1. DefiniciĂłn de las macros identificadas
2. RealizaciĂłn del âmainâ que incluye declaraciĂłn de los arreglos mazo, Jugador y
Computadora.
3. RealizaciĂłn de las funciones: sĂ­mbolocarta, valorcarta, tomarcarta.
4. Desde el âmainâ iniciar la iteraciĂłn entre computador y jugador permitiendo seleccionar
las cartas e indicando el total que van acumulando.
5. Realizar las funciones showcart_xy y sumarcarta.
6. Controlar las situaciones del juego:
a. Indicar al jugador cuando pierde
b. La computadora debe pedir una carta adicional siempre y cuando no sume 21 y el
jugador no haya perdido.
7. El jugador podrĂĄ jugar cuantos juegos desee
8. Al finalizar el juego se debe presentar la cantidad de juegos jugados, ganados y perdidos.*/ 

#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <conio.h>

#define MAXCARTAS 52
#define MAXCARTAREP 11
#define BLACKJACK 21
#define ESI 218
#define ESD 191
#define LH 196
#define EII 192
#define EID 217
#define LV 179


int randrange(int liminf, int limsup);
int simbolocarta(int indice);
int valorcarta(int indice);
int tomarcarta(int mazo[ ]);
void showcart_xy(int indice, int px, int py);
int sumacarta(int cartas[ ], int n);
int valcart(int indice);



int main()
{
   srand(time(NULL));

   int mazo[MAXCARTAS] = {0};
   int jugador[MAXCARTAREP];
   int computadora[MAXCARTAREP];
   showcart_xy(5, 5, 5);

   return 0;    
}

int simbolocarta(int indice){
    
   return indice % 4; 
}

int valorcarta(int indice)
{      
   return (indice / 4) + 1;
}

int tomarcarta (int mazo[])
{
   int indice;
   do{
      indice = randrange(0, MAXCARTAS - 1);
   }while (mazo[indice]);
   mazo[indice] = 1;
   return indice;
}





int randrange(int liminf, int limsup)
{
   return rand() % (limsup - liminf + 1) + liminf;
}





void showcart_xy(int indice, int px, int py)
{
   gotoxy(px,py);
   printf("%c%c%c%c%c%c%c%c%c", ESI, LH, LH, LH, LH, LH, LH, LH, ESD);
   gotoxy(px,py+1);
   printf("%c%c%c%c%c%c%c%c%c", LV, ' ', ' ', ' ', ' ', ' ', ' ', ' ', LV);
   gotoxy(px,py+2);
   printf("%c%c%c%c%c%c%c%c%c", LV, ' ', ' ', ' ', ' ', ' ', ' ', ' ', LV);
   gotoxy(px,py+3);
   printf("%c%c%c%c%c%c%c%c%c", LV, ' ', ' ', ' ',3 , ' ', ' ', ' ', LV);
   gotoxy(px,py+4);
   printf("%c%c%c%c%c%c%c%c%c", LV, ' ', ' ', ' ', ' ', ' ', ' ', ' ', LV);
   gotoxy(px,py+5);
   printf("%c%c%c%c%c%c%c%c%c", LV, ' ', ' ', ' ', ' ', ' ', ' ', ' ', LV);
   gotoxy(px,py+6);
   printf("%c%c%c%c%c%c%c%c%c", EII, LH, LH, LH, LH, LH, LH, LH, EID);


   
   //printf("%c%c%c%c%c%c", 192, 196, 196, 196, 196, 217);
}


int valcart(int indice)
{
   int val = valorcarta(indice);

   if ( val >= 10 )
      return 10;
   return val;
}


int sumacarta(int cartas[ ], int n)
{
   int total = 0, cantA = 0, valorcart;
   for (int ind = 0; ind < n; ind++)
   {
      valorcart = valcart(cartas[ind]);
      if ( valorcart == 1)
      {
         cantA++;
         total += valorcart + 10;
      }
      else
         total += valorcart;
   }

   while ( total > BLACKJACK && (cantA > 0))
   {
      total -= 10, cantA--;
   }
} 
