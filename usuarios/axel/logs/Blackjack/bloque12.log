int valcart(int indice)
{
   int val = valorcarta(indice);

   if ( val >= 10 )
   {
      return 10;
   }  
   else
      return val;
}


int sumacarta(int cartas[ ], int n)
{
   int total = 0, cantA = 0, valorcart;
   for (int ind = 0; ind < n; ind++)
   {
      valorcart = valcart(cartas[ind]);
      if ( valorcart == 1)
      {
         cantA++;
         total += valorcart + 10;
      }
      else
         total += valorcart;
   }

   while ( total > BLACKJACK && (cantA > 0))
   {
      total -= 10, cantA--;
   }

   return total;
} 
