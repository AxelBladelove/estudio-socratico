   printf("%c%c%c%c%c%c%c%c%c", LV, ' ', ' ', ' ', TREBOL, ' ', ' ', ' ', LV);
   gotoxy(px,py+4);
   printf("%c%c%c%c%c%c%c%c%c", LV, ' ', ' ', ' ', ' ', ' ', ' ', ' ', LV);
