			if (marcadas[col][fil] == 1)
			{
				setcolor(CMT, CMF);
			}
			if (col == col_actual && fil == fil_actual)
			{
				setcolor(CT, CCSF);
			}
			if (marcadas[col][fil] == 1 && (col == col_actual && fil == fil_actual))
			{
