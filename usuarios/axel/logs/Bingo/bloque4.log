#define ALTO_CASILLA  1

#define BOLASTOTAL 75
#define B 1
#define I 2
#define N 3
#define G 4
#define O 5
#define bingoposY 7
#define POS_B 47 
#define POS_I 51 
#define POS_N 55 
#define POS_G 59
#define POS_O 63



int buscarymarcar (int carton[dim][dim], int marcadas[dim][dim], int bola);
void setcolor(int ct, int cf);
void colordefault(void);
void llenar_carton (int carton[dim][dim], int num_carton[BOLASTOTAL]);
