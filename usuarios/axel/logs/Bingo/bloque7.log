int numerar_carton (int Grupo, int num_carton[BOLASTOTAL])
{
	int indice;
	int indice_temp;
	do
	{
		indice_temp =  randrange(1, BOLASTOTAL);
		indice = indice_temp;
		indice_temp = (((indice_temp - 1) / 15) + 1);
