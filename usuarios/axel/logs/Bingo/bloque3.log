#define ENTER     13
#define ESC       27
#define ARRIBA    72
#define ABAJO     80
#define DERECHA   77
#define IZQUIERDA 75
#define ESP       32
#define CT      	LIGHTBLUE
#define CF 			WHITE
#define ANCHO_CASILLA 6
#define ALTO_CASILLA  3

#define BOLASTOTAL 75
#define B 1
#define I 2
#define N 3
#define G 4
#define O 5


