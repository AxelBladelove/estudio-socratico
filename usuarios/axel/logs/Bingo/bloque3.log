			}
			if (col == 4)
			{
				carton[col][fil] = numerar_carton(O, bolillero);	
			}
			gotoxy(posx+(col*(5+1)),posy+fil);
			printf("%d\t", carton[col][fil]);

		}
		printf("\n");
	}	
}




