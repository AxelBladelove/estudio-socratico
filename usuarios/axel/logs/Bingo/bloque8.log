{
	GRUPO = GRUPO;
	return bolas(bolillero);
}

int numerar_carton (int Grupo, int num_carton[BOLASTOTAL + 1])
{
	int indice;
	int indice_temp;

	while (1)
	{
		indice_temp =  randrange(1, BOLASTOTAL);
		indice = indice_temp;
		indice_temp = (((indice_temp - 1) / 15) + 1);
		if (indice_temp == Grupo && num_carton[indice] == 0)
		{
			num_carton[indice] = 1;
			return indice;
		}
		
	}
}


void setcolor(int ct, int cf)
{
   textbackground(cf);
   textcolor(ct);
}


void colordefault(void)
{
   setcolor(LIGHTGRAY,BLACK);
}




void llenar_carton (int carton[dim][dim], int num_carton[BOLASTOTAL + 1])
{
	int col;
	int fil;

	for (col = 0; col <= BOLASTOTAL; col++)
	{
		num_carton[col] = 0;
	}

	for (col = 0; col < dim; col++)
	{
		for (fil = 0; fil < dim; fil++)
		{	
			if (col == 0) carton[col][fil] = numerar_carton(B, num_carton);
			if (col == 1) carton[col][fil] = numerar_carton(I, num_carton);
			if (col == 2) carton[col][fil] = numerar_carton(N, num_carton);
			if (col == 3) carton[col][fil] = numerar_carton(G, num_carton);
			if (col == 4) carton[col][fil] = numerar_carton(O, num_carton);
		}		
	}
}

void LetrasBingo (void)
{
	int dx;

	setcolor(CF, colortext);

	gotoxy(POS_B - 2, bingoposY);
	for (dx = 0; dx < (ANCHO_CASILLA * 5); dx++) printf(" ");

	gotoxy(POS_B, bingoposY);
	printf("B");	
	gotoxy(POS_I, bingoposY);
	printf("I");
	gotoxy(POS_N, bingoposY);
	printf("N");
	gotoxy(POS_G, bingoposY);
	printf("G");
	gotoxy(POS_O, bingoposY);
	printf("O");

}


int buscarbola (int carton[dim][dim], int bola)
{
	int fil;
	int col;
	int si = 0;
	for (col = 0; col < dim; col++)
	{
		for (fil = 0; fil < dim; fil++)
		{
			if (carton[col][fil] == bola)
			{
				si = 1;
				return si;
			}
		}	
	}
	return 0;
}

int buscarbola_pos (int carton[dim][dim], int bola, int *col_bola, int *fil_bola)
{
	int fil;
	int col;

	for (col = 0; col < dim; col++)
	{
		for (fil = 0; fil < dim; fil++)
		{
			if (carton[col][fil] == bola)
			{
				*col_bola = col;
				*fil_bola = fil;
				return 1;
			}
		}
	}

	*col_bola = -1;
	*fil_bola = -1;
	return 0;
}


void iniciar_carton(int marcadas[dim][dim])
{
	for (int col = 0; col < dim; col++)
	{
		for (int fil = 0; fil < dim; fil++)
		{
			marcadas[col][fil] = 0;

			if (col == 2 && fil == 2)
			{
				marcadas[col][fil] = 1;
			}	
		}	
	}
}

void mostrarbola (int bola)
{
	int grupo;
	int color;

	grupo = (((bola - 1) / 15) + 1);

	color = randrange(1,4);
	if (color == 1) setcolor(CT, CCSF);
	if (color == 2) setcolor(CMT, CMF);
	if (color == 3) setcolor(CF, colortext);
	if (color == 4) setcolor(colortext, CF);

	gotoxy(POS_BOLAX, POS_BOLAY);
	printf("      ");
	gotoxy(POS_BOLAX - 1, POS_BOLAY + 1);
	printf("        ");
	gotoxy(POS_BOLAX - 2, POS_BOLAY + 2);
	printf("          ");
	gotoxy(POS_BOLAX - 1, POS_BOLAY + 3);
	printf("        ");
	gotoxy(POS_BOLAX, POS_BOLAY + 4);
	printf("      ");

	gotoxy(POS_BOLAX + BOLA_TEXTO_DX, POS_BOLAY + BOLA_TEXTO_DY);
	if (grupo == B) printf("B-%2d", bola);
	if (grupo == I) printf("I-%2d", bola);
	if (grupo == N) printf("N-%2d", bola);
	if (grupo == G) printf("G-%2d", bola);
	if (grupo == O) printf("O-%2d", bola);
}

int haylinea (int marcadas[dim][dim])
{
	int fil;
	int col;
	int cont;

	for (fil = 0; fil < dim; fil++)
	{
		cont = 0;
		for (col = 0; col < dim; col++)
		{
			if (marcadas[col][fil] == 1) cont++;
		}
		if (cont == dim) return 1;
	}

	for (col = 0; col < dim; col++)
	{
		cont = 0;
		for (fil = 0; fil < dim; fil++)
		{
			if (marcadas[col][fil] == 1) cont++;
		}
		if (cont == dim) return 1;
	}

	cont = 0;
	for (fil = 0; fil < dim; fil++)
	{
		if (marcadas[fil][fil] == 1) cont++;
	}
	if (cont == dim) return 1;

	cont = 0;
	for (fil = 0; fil < dim; fil++)
	{
		if (marcadas[dim - 1 - fil][fil] == 1) cont++;
	}
	if (cont == dim) return 1;

	return 0;
}

int cartonlleno (int marcadas[dim][dim])
{
	int fil;
	int col;

	for (col = 0; col < dim; col++)
	{
		for (fil = 0; fil < dim; fil++)
		{
			if (marcadas[col][fil] == 0)
			{
				return 0;
			}
		}
	}

	return 1;
}

int leer_tecla (void)
{
	int tecla;

	tecla = getch();
	if (tecla == 0 || tecla == 224)
	{
		tecla = getch();
	}

	return tecla;
}

void limpiararea (int posx, int posy, int ancho, int largo)
{
	int fil;
	int col;

	colordefault();
	for (fil = 0; fil < largo; fil++)
	{
		gotoxy(posx, posy + fil);
		for (col = 0; col < ancho; col++)
		{
			printf(" ");
		}
	}
}

void mostrar_stats (int jugadas, int ganadas, int perdidas, float multas)
{
	colordefault();
	limpiararea(3, 21, 75, 3);
	gotoxy(3,21);
	printf("Estadisticas -> Jugadas: %d  Ganadas: %d  Perdidas: %d", jugadas, ganadas, perdidas);
	gotoxy(3,22);
	printf("Multas acumuladas: %.2f", multas);
	gotoxy(3,23);
	printf("Presiona cualquier tecla para seguir.");
	leer_tecla();
	limpiararea(3, 21, 75, 3);
}

void mostrar_ayuda_juego (void)
{
	colordefault();
	gotoxy(3,2);
	printf("Flechas: mover selector");
	gotoxy(3,3);
	printf("ENTER: marcar bola");
	gotoxy(3,4);
	printf("ESC: la bola no esta");
	gotoxy(3,5);
	printf("E: estadisticas");
	gotoxy(3,6);
	printf("Q: salir");
}


 
