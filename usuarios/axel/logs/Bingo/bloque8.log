/* Realizar un programa interactivo en C que simule un juego de bingo con un cartón. Este debe presentarse
gráficamente, identificando con un color diferente los recuadros de las bolas que han salido. El juego
generará el cartón de forma aleatoria. Asegúrese que una combinación no se repita para cada columna
del cartón. Tome en cuenta que cada una de las letras de bingo corresponde a un cierto rango de
números, como se indica a continuación.
B: 1-15
I: 16-30
N: 31-45
G: 46-60
O: 61-75
El cartón tendrá cinco columnas, rotuladas B-I-N-G-O. Cada columna contendrá cinco números, dentro
de los rangos indicados arriba. La posición central de cada cartón se cubre antes de comenzar el juego
(jugada gratis). Se gana cuando se tenga una línea de números sacados (en vertical, horizontal o en
diagonal). Luego de esto se preguntará si se desea jugar a cartón lleno y en caso de ser afirmativo se debe
continuar sacando bolos. Cada vez que termine una mano se debe preguntar si se desea continuar
jugando. Se debe presentar las estadísticas de ganados vs perdidos en el momento que el usuario desee.
Una vez iniciado el juego se presenta una bola que se genera de manera aleatoria, sin repetición. El
usuario presionará [ENTER] sobre la bola en su cartón y en caso de que no esté presionará [ESC]. Si el
usuario presiona [ESC] y la bola está en el cartón se le descuenta el 10% de lo apostado. Se debe presentar
la bola generada, en un área de la pantalla conjuntamente con la información del cartón. El usuario puede cambiar de cartón cuantas veces lo desee antes de comenzar el juego. */



#include <stdio.h>
#include <stdlib.h>
#include <conio.h>
#include <time.h>

#define dim 	  	5
#define ENTER     13
#define ESC       27
#define ARRIBA    72
#define ABAJO     80
#define DERECHA   77
#define IZQUIERDA 75
#define ESP       32
#define CT      	LIGHTBLUE
#define CF 			WHITE
#define colortext RED
#define CMT 		CYAN
#define CMF 		DARKGRAY
#define CCSF 		YELLOW
#define ANCHO_CASILLA 4
#define ALTO_CASILLA  1

#define BOLASTOTAL 75
#define B 			1
#define I 			2
#define N 			3
#define G 			4
#define O 			5
#define bingoposY 7
#define POS_B 		27 
#define POS_I 		31 
#define POS_N 		35 
#define POS_G 		39
#define POS_O 		43
#define POS_BOLAX 65
#define POS_BOLAY 7
#define BOLA_TEXTO_DX 1
#define BOLA_TEXTO_DY 2


int buscarbola (int carton[dim][dim], int bola);
int buscarbola_pos (int carton[dim][dim], int bola, int *col_bola, int *fil_bola);
void setcolor(int ct, int cf);
void colordefault(void);
void llenar_carton (int carton[dim][dim], int num_carton[BOLASTOTAL + 1]);
void LetrasBingo (void);
void showcarton (int carton[dim][dim], int marcadas[dim][dim], int col_actual, int fil_actual, int posx, int posy);
int bolas (int bolillero[BOLASTOTAL + 1]);
int sacarbolas🥚🥚(int Grupo, int bolillero[BOLASTOTAL + 1]);
int randrange (int limif, int limsp);
int numerar_carton (int Grupo, int num_carton[BOLASTOTAL + 1]);
void iniciar_carton (int marcadas[dim][dim]);
void mostrarbola (int bola);
int haylinea (int marcadas[dim][dim]);
int cartonlleno (int marcadas[dim][dim]);
int leer_tecla (void);
void limpiararea (int posx, int posy, int ancho, int largo);
void mostrar_stats (int jugadas, int ganadas, int perdidas, float multas);
void mostrar_ayuda_juego (void);


int main(){

	int jugando = 1;
	int carton[dim][dim];
	int bolillero[BOLASTOTAL + 1];
	int num_carton[BOLASTOTAL + 1];
	int marcadas[dim][dim];
	int bola;
	int fil_actual;
	int col_actual;
	int fil_bola;
	int col_bola;
	int tecla;
	int pre_juego;
	int mano_actual;
	int bolas_sacadas;
	int en_carton;
	int jugadas = 0;
	int ganadas = 0;
	int perdidas = 0;
	int jugar_carton_lleno;
	float apuesta;
	float multas = 0;

	srand(time(NULL));
	
	while (jugando == 1)
	{
		system("cls");
		apuesta = 0;
		do
		{
			colordefault();
			gotoxy(3,2);
			printf("Apuesta de esta mano: ");
			scanf("%f", &apuesta);
			while (getchar() != '\n');
			if (apuesta <= 0)
			{
				gotoxy(3,3);
				printf("La apuesta debe ser mayor que cero.");
			}
		} while (apuesta <= 0);

		pre_juego = 1;
		while (pre_juego == 1)
		{
			system("cls");
			llenar_carton(carton, num_carton);
			iniciar_carton(marcadas);
			showcarton(carton, marcadas, -1, -1, 25, 8);
			colordefault();
			gotoxy(3,2);
			printf("ESP: cambiar de carton");
			gotoxy(3,3);
			printf("ENTER: comenzar");
			gotoxy(3,4);
			printf("D: salir");
			tecla = leer_tecla();

			if (tecla == ENTER)
			{
				pre_juego = 0;
			}
			else if (tecla == 'd' || tecla == 'D')
			{
				pre_juego = 0;
				jugando = 0;
			}
		}

		if (jugando == 0)
		{
			break;
		}

		for (int ind = 0; ind <= BOLASTOTAL; ind++)
		{
			bolillero[ind] = 0;
		}

		fil_actual = 0;
		col_actual = 0;
		bolas_sacadas = 0;
		mano_actual = 1;
		jugar_carton_lleno = 0;

		system("cls");
		showcarton(carton, marcadas, col_actual, fil_actual, 25, 8);
		mostrar_ayuda_juego();

		while (mano_actual == 1 && bolas_sacadas < BOLASTOTAL)
		{
			bola = bolas(bolillero);
			bolas_sacadas++;
			en_carton = buscarbola_pos(carton, bola, &col_bola, &fil_bola);
			mostrarbola(bola);

			do
			{
				showcarton(carton, marcadas, col_actual, fil_actual, 25, 8);
				mostrarbola(bola);
				colordefault();
				limpiararea(3, 17, 75, 4);
				gotoxy(3,17);
				printf("Bola actual: %d", bola);
				gotoxy(3,18);
				printf("ENTER marca la casilla seleccionada. ESC dice que no esta.");
				gotoxy(3,19);
				printf("Flechas para moverte. E muestra estadisticas. Q sale.");

				tecla = leer_tecla();

				if (tecla == IZQUIERDA && col_actual > 0) col_actual--;
				if (tecla == DERECHA && col_actual < dim - 1) col_actual++;
				if (tecla == ARRIBA && fil_actual > 0) fil_actual--;
				if (tecla == ABAJO && fil_actual < dim - 1) fil_actual++;

				if (tecla == 'e' || tecla == 'E')
				{
					mostrar_stats(jugadas, ganadas, perdidas, multas);
				}

				if (tecla == 'q' || tecla == 'Q')
				{
					mano_actual = 0;
					jugando = 0;
				}

				if (tecla == ENTER)
				{
					if (carton[col_actual][fil_actual] == bola)
					{
						marcadas[col_actual][fil_actual] = 1;
						colordefault();
						limpiararea(3, 17, 75, 4);
						gotoxy(3,17);
						printf("Bien marcada.");
					}
					else
					{
						colordefault();
						gotoxy(3,20);
						printf("Esa casilla no es la bola actual.");
						tecla = 0;
					}
				}

				if (tecla == ESC)
				{
					if (en_carton == 1 && marcadas[col_bola][fil_bola] == 0)
					{
						multas += apuesta * 0.10;
						colordefault();
						limpiararea(3, 17, 75, 4);
						gotoxy(3,17);
						printf("La bola si estaba en el carton. Multa acumulada: %.2f", multas);
					}
					else
					{
						colordefault();
						limpiararea(3, 17, 75, 4);
						gotoxy(3,17);
						printf("Correcto, esa bola no esta pendiente en tu carton.");
					}
				}

			} while (tecla != ENTER && tecla != ESC && mano_actual == 1);

			if (mano_actual == 1)
			{
				if (jugar_carton_lleno == 0 && haylinea(marcadas) == 1)
				{
					showcarton(carton, marcadas, col_actual, fil_actual, 25, 8);
					colordefault();
					limpiararea(3, 17, 75, 5);
					gotoxy(3,17);
					printf("BINGO. Ya tienes una linea.");
					gotoxy(3,18);
					printf("Quieres seguir a carton lleno? S/N");

					do
					{
						tecla = leer_tecla();
					} while (tecla != 's' && tecla != 'S' && tecla != 'n' && tecla != 'N');

					if (tecla == 's' || tecla == 'S')
					{
						jugar_carton_lleno = 1;
					}
					else
					{
						ganadas++;
						jugadas++;
						mano_actual = 0;
					}
				}

				if (jugar_carton_lleno == 1 && cartonlleno(marcadas) == 1)
				{
					ganadas++;
					jugadas++;
					mano_actual = 0;
					colordefault();
					limpiararea(3, 17, 75, 5);
					gotoxy(3,17);
					printf("Carton lleno. Ganaste la mano.");
				}
			}
		}

		if (mano_actual == 1 && bolas_sacadas >= BOLASTOTAL)
		{
			perdidas++;
			jugadas++;
			mano_actual = 0;
			colordefault();
			limpiararea(3, 17, 75, 5);
			gotoxy(3,17);
			printf("Salieron todas las bolas. Mano perdida.");
		}

		if (jugando == 1)
		{
			colordefault();
			gotoxy(3,23);
			printf("Jugadas: %d  Ganadas: %d  Perdidas: %d  Multas: %.2f", jugadas, ganadas, perdidas, multas);
			gotoxy(3,24);
			printf("A: jugar otra mano   D: salir");

			do
			{
				tecla = leer_tecla();
			} while (tecla != 'a' && tecla != 'A' && tecla != 'd' && tecla != 'D');

			if (tecla == 'd' || tecla == 'D')
			{
				jugando = 0;
			}
		}
	}

	system("cls");
	colordefault();
	gotoxy(3,3);
	printf("Resumen final -> Jugadas: %d  Ganadas: %d  Perdidas: %d  Multas: %.2f", jugadas, ganadas, perdidas, multas);

	return 0;
}

void showcarton (int carton[dim][dim], int marcadas[dim][dim], int col_actual, int fil_actual, int posx, int posy)
{
	int fil;
	int col;
	int dx;
	int dy;

	LetrasBingo();


	for (fil = 0; fil < dim; fil++)
	{
	
		for (col = 0; col < dim; col++)
		{
			if (marcadas[col][fil] == 1 && col == col_actual && fil == fil_actual && col_actual != -1 && fil_actual != -1)
			{
				setcolor(CCSF, CF);
			}
			else if (marcadas[col][fil] == 1)
			{
				setcolor(CMT, CMF);
			}
			else if (col == col_actual && fil == fil_actual && col_actual != -1 && fil_actual != -1)
			{
				setcolor(CT, CCSF);
			}		
			else
			{
				setcolor(CT, CF);
			}
			for (dy = 0; dy < ALTO_CASILLA; dy++)
			{
				gotoxy(posx + col * ANCHO_CASILLA, posy + fil * ALTO_CASILLA + dy);
				for (dx = 0; dx < ANCHO_CASILLA; dx++)
				{
					printf(" ");
				}
			}
			gotoxy(posx + col * ANCHO_CASILLA + 1, posy + fil * ALTO_CASILLA);
			printf("%2d", carton[col][fil]);
		}
	}	
}




/*Recibe el arreglo del total de volas y me retorna de manera aleatoria el indice de una posicion que no ha salido antes*/

int bolas (int bolillero[BOLASTOTAL + 1])
{
	int indice;
	do
	{
		indice =  randrange(1, BOLASTOTAL);
	} while (bolillero[indice] == 1);
	bolillero[indice] = 1;
	
	return indice;  
}




int randrange(int limif,int limsp)
{
	return (rand() % (limsp - limif + 1) + limif);
}

