				printf("Linea. Carton lleno? S/N      ");

				do
				{
					tecla = getch();
				} while (tecla != 'S' && tecla != 's' && tecla != 'N' && tecla != 'n');

				if (tecla == 'S' || tecla == 's')
				{
					carton_lleno = 1;
					gotoxy(3,15);
					printf("Carton lleno.                 ");
				}
				else
				{
					mano_terminada = 1;
				}
			}

			if (carton_lleno == 1 && verificarcartonlleno(marcadas) == 1)
			{
				mano_terminada = 1;
				gotoxy(3,15);
				printf("Carton lleno completado.      ");
			}

			if (bolas_sacadas == BOLASTOTAL && mano_terminada == 0)
			{
				mano_terminada = 1;
				gotoxy(3,15);
				printf("Sin bolas.                    ");
			}
		}

		if (mano_ganada == 1)
		{
			ganadas++;
		}
		else
		{
			perdidas++;
		}

		mostrarstats(ganadas, perdidas, apuesta);
		gotoxy(3,16);
		printf("Seguir? S/N                   ");

		do
		{
			tecla = getch();
		} while (tecla != 'S' && tecla != 's' && tecla != 'N' && tecla != 'n');

		if (tecla == 'N' || tecla == 'n')
		{
			jugando = 0;
		}
	}

	_setcursortype(100);
	colordefault();
	gotoxy(3,18);
	printf("Ganadas: %d  Perdidas: %d", ganadas, perdidas);



	return 0;
}

