int main(){

	int jugando = 1;
	int carton[dim][dim];
	int bolillero[BOLASTOTAL + 1] = {0};
	int num_carton[BOLASTOTAL + 1] = {0};
	int marcadas[dim][dim] = {0};
	int bola;
	int fil_actual = -1;
	int col_actual = -1;
	int prejuego = 1;
	int tecla;
	int ganadas = 0;
	int perdidas = 0;
	int apuesta = 0;
	int bolas_sacadas;
	int mano_terminada;
	int mano_ganada;
	int carton_lleno;
	int col_anterior;
	int fil_anterior;
	int turno_resuelto;

	srand(time(NULL));
	_setcursortype(0);
	
	while (jugando == 1)
	{
		prejuego = 1;
		col_actual = -1;
		fil_actual = -1;
		carton_lleno = 0;
		apuesta = 0;

		iniciar_vector(num_carton);
		iniciar_vector(bolillero);
		llenar_carton(carton, num_carton);
		iniciar_carton(marcadas);
		showcarton(carton, marcadas, col_actual, fil_actual, 25, 8);
		mostrarbola(0);
		colordefault();
		gotoxy(3,2);
		printf("ESP: cambiar de carton         ");
		gotoxy(3,3);
		printf("ENTER: comenzar juego         ");
		gotoxy(3,4);
		printf("ESC: salir                    ");
		gotoxy(3,12);
		printf("                              ");
		gotoxy(3,13);
		printf("                              ");
		gotoxy(3,14);
		printf("                              ");
		mostrarstats(ganadas, perdidas, apuesta);

		while (prejuego == 1)
		{
			do
			{
				tecla = getch();
			} while (tecla != ESP && tecla != ENTER && tecla != ESC);

			if (tecla == ESP)
			{
				iniciar_vector(num_carton);
				llenar_carton(carton, num_carton);
				iniciar_carton(marcadas);
				showcarton(carton, marcadas, col_actual, fil_actual, 25, 8);
			}

			if (tecla == ENTER)
			{
				prejuego = 0;
			}

			if (tecla == ESC)
			{
				prejuego = 0;
				jugando = 0;
			}
		}

		if (jugando == 0)
		{
			break;
		}

		colordefault();
		gotoxy(3,5);
		printf("Apuesta de la mano:           ");
		gotoxy(22,5);
		scanf("%d", &apuesta);
		if (apuesta < 0) apuesta = 0;
		mostrarstats(ganadas, perdidas, apuesta);

		gotoxy(3,2);
		printf("Flechas: mover cursor         ");
		gotoxy(3,3);
		printf("ENTER: marcar la bola         ");
		gotoxy(3,4);
		printf("ESC: la bola no esta          ");

		col_actual = 0;
		fil_actual = 0;
		showcarton(carton, marcadas, col_actual, fil_actual, 25, 8);

		bolas_sacadas = 0;
		mano_terminada = 0;
		mano_ganada = 0;

		while (mano_terminada == 0)
		{
			bola = sacarbolas((randrange(1, 5)), bolillero);
			bolas_sacadas++;
			mostrarbola(bola);
			gotoxy(3,12);
			printf("Ubique la bola en el carton.  ");
			gotoxy(3,13);
			printf("                              ");
			turno_resuelto = 0;

			do
			{
				do
				{
					tecla = getch();
				} while (tecla != ENTER && tecla != ARRIBA && tecla != ABAJO &&
						 tecla != DERECHA && tecla != IZQUIERDA && tecla != ESC);

				col_anterior = col_actual;
				fil_anterior = fil_actual;

				if ( tecla == IZQUIERDA )
					if ( col_actual > 0 )
					{
						col_actual--;
						showcasilla(carton, marcadas, col_actual, fil_actual, col_anterior, fil_anterior, 25, 8);
						showcasilla(carton, marcadas, col_actual, fil_actual, col_actual, fil_actual, 25, 8);
					}

				if ( tecla == ARRIBA )
					if ( fil_actual > 0 )
					{
						fil_actual--;
						showcasilla(carton, marcadas, col_actual, fil_actual, col_anterior, fil_anterior, 25, 8);
						showcasilla(carton, marcadas, col_actual, fil_actual, col_actual, fil_actual, 25, 8);
					}

				if ( tecla == DERECHA )
					if ( col_actual < dim - 1 )
					{
						col_actual++;
						showcasilla(carton, marcadas, col_actual, fil_actual, col_anterior, fil_anterior, 25, 8);
						showcasilla(carton, marcadas, col_actual, fil_actual, col_actual, fil_actual, 25, 8);
					}

				if ( tecla == ABAJO )
					if ( fil_actual < dim - 1 )
					{
						fil_actual++;
						showcasilla(carton, marcadas, col_actual, fil_actual, col_anterior, fil_anterior, 25, 8);
						showcasilla(carton, marcadas, col_actual, fil_actual, col_actual, fil_actual, 25, 8);
					}

				if (tecla == ENTER)
				{
					if (carton[col_actual][fil_actual] == bola)
					{
						marcadas[col_actual][fil_actual] = 1;
						showcasilla(carton, marcadas, col_actual, fil_actual, col_actual, fil_actual, 25, 8);
						gotoxy(3,12);
						printf("Marcaste la bola correctamente.");
						turno_resuelto = 1;
					}
					else
					{
						gotoxy(3,12);
						printf("Esa no es la bola. Sigue buscando.");
					}
				}

				if (tecla == ESC)
				{
					if (buscarbola(carton, bola) == 1)
					{
						apuesta = apuesta - (apuesta / 10);
						if (apuesta < 0) apuesta = 0;
						mostrarstats(ganadas, perdidas, apuesta);
						gotoxy(3,12);
						printf("La bola si estaba. Pierdes 10%%.");
					}
					else
					{
						gotoxy(3,12);
						printf("Correcto. La bola no estaba.  ");
					}
					turno_resuelto = 1;
				}
			} while (turno_resuelto == 0);

			if (mano_ganada == 0 && verificarlinea(marcadas) == 1)
			{
				mano_ganada = 1;
				gotoxy(3,13);
				printf("Hiciste linea. Carton lleno? S/N");

				do
				{
					tecla = getch();
				} while (tecla != 'S' && tecla != 's' && tecla != 'N' && tecla != 'n');

				if (tecla == 'S' || tecla == 's')
				{
					carton_lleno = 1;
					gotoxy(3,13);
					printf("Sigue jugando a carton lleno.  ");
				}
				else
				{
					mano_terminada = 1;
				}
			}

			if (carton_lleno == 1 && verificarcartonlleno(marcadas) == 1)
			{
				mano_terminada = 1;
				gotoxy(3,13);
				printf("Completaste el carton lleno.   ");
			}

			if (bolas_sacadas == BOLASTOTAL && mano_terminada == 0)
			{
				mano_terminada = 1;
				gotoxy(3,13);
				printf("Se acabaron las bolas.         ");
			}
		}

		if (mano_ganada == 1)
		{
			ganadas++;
		}
		else
		{
			perdidas++;
		}

		mostrarstats(ganadas, perdidas, apuesta);
		gotoxy(3,14);
		printf("Desea seguir jugando? S/N      ");

		do
		{
			tecla = getch();
		} while (tecla != 'S' && tecla != 's' && tecla != 'N' && tecla != 'n');

		if (tecla == 'N' || tecla == 'n')
		{
			jugando = 0;
		}
	}

	_setcursortype(100);
	colordefault();
	gotoxy(3,16);
	printf("Ganadas: %d  Perdidas: %d", ganadas, perdidas);



	return 0;
}

void showcasilla (int carton[dim][dim], int marcadas[dim][dim], int col_actual, int fil_actual, int col, int fil, int posx, int posy)
{
	int dx;
	int dy;

	if (marcadas[col][fil] == 1 && col == col_actual && fil == fil_actual && col_actual != -1 && fil_actual != -1)
	{
		setcolor(CCSF, CF);
	}
	else if (marcadas[col][fil] == 1)
	{
		setcolor(CMT, CMF);
	}
	else if (col == col_actual && fil == fil_actual && col_actual != -1 && fil_actual != -1)
	{
		setcolor(CT, CCSF);
	}
	else
	{
		setcolor(CT, CF);
	}

	for (dy = 0; dy < ALTO_CASILLA; dy++)
	{
		gotoxy(posx + col * ANCHO_CASILLA, posy + fil * ALTO_CASILLA + dy);
		for (dx = 0; dx < ANCHO_CASILLA; dx++)
		{
			printf(" ");
		}
	}

	gotoxy(posx + col * ANCHO_CASILLA + 1, posy + fil * ALTO_CASILLA);
	printf("%2d", carton[col][fil]);
}

void showcarton (int carton[dim][dim], int marcadas[dim][dim], int col_actual, int fil_actual, int posx, int posy)
{
	int fil;
	int col;

	LetrasBingo();


	for (fil = 0; fil < dim; fil++)
	{
	
		for (col = 0; col < dim; col++)
		{
			showcasilla(carton, marcadas, col_actual, fil_actual, col, fil, posx, posy);
		}
	}	
}




/*Recibe el arreglo del total de volas y me retorna de manera aleatoria el indice de una posicion que no ha salido antes*/

int bolas (int bolillero[BOLASTOTAL])
{
	int indice;
	do
	{
		indice =  randrange(1, BOLASTOTAL);
	} while (bolillero[indice] == 1);
	bolillero[indice] = 1;
	
	return indice;  
}




int randrange(int limif,int limsp)
{
	return (rand() % (limsp - limif + 1) + limif);
}

/**/
int sacarbolas (int GRUPO, int bolillero[BOLASTOTAL])
{
	int indice;
	int indice_temp;

	do
	{
		indice_temp = bolas(bolillero);
		indice = indice_temp;
		indice_temp = (((indice_temp - 1) / 15) + 1);
	} while (indice_temp != GRUPO);	

	return indice;
}

int numerar_carton (int Grupo, int num_carton[BOLASTOTAL])
{
	int indice;
	int indice_temp;
	do
	{
		indice_temp =  randrange(1, BOLASTOTAL);
		indice = indice_temp;
		indice_temp = (((indice_temp - 1) / 15) + 1);
		if (indice_temp == Grupo && num_carton[indice] == 0)
		{
			num_carton[indice] = 1;
			return indice;
		}
		
	} while (num_carton[indice] == 1 || indice_temp != Grupo);
}


void setcolor(int ct, int cf)
{
   textbackground(cf);
   textcolor(ct);
}


void colordefault(void)
{
   setcolor(LIGHTGRAY,BLACK);
}




void llenar_carton (int carton[dim][dim], int num_carton[BOLASTOTAL])
{
	int col;
	int fil;

	for (col = 0; col < dim; col++)
	{
		for (fil = 0; fil < dim; fil++)
		{	
			if (col == 0) carton[col][fil] = numerar_carton(B, num_carton);
			if (col == 1) carton[col][fil] = numerar_carton(I, num_carton);
			if (col == 2) carton[col][fil] = numerar_carton(N, num_carton);
			if (col == 3) carton[col][fil] = numerar_carton(G, num_carton);
			if (col == 4) carton[col][fil] = numerar_carton(O, num_carton);
		}		
	}
}

void LetrasBingo (void)
{
	int dx;

	setcolor(CF, colortext);

	gotoxy(POS_B - 2, bingoposY);
	for (dx = 0; dx < (ANCHO_CASILLA * 5); dx++) printf(" ");

	gotoxy(POS_B, bingoposY);
	printf("B");	
	gotoxy(POS_I, bingoposY);
	printf("I");
	gotoxy(POS_N, bingoposY);
	printf("N");
	gotoxy(POS_G, bingoposY);
	printf("G");
	gotoxy(POS_O, bingoposY);
	printf("O");

}


int buscarbola (int carton[dim][dim], int bola)
{
	int fil;
	int col;
	int si = 0;
	for (col = 0; col < dim; col++)
	{
		for (fil = 0; fil < dim; fil++)
		{
			if (carton[col][fil] == bola)
			{
				si = 1;
				return si;
			}
		}	
	}
	return 0;
}


void iniciar_carton(int marcadas[dim][dim])
{
	for (int col = 0; col < dim; col++)
	{
		for (int fil = 0; fil < dim; fil++)
		{
			marcadas[col][fil] = 0;

			if (col == 2 && fil == 2)
			{
				marcadas[col][fil] = 1;
			}	
		}	
	}
}

void iniciar_vector(int vec[BOLASTOTAL + 1])
{
	int indice;
	for (indice = 0; indice <= BOLASTOTAL; indice++)
	{
		vec[indice] = 0;
	}
}

int verificarlinea (int marcadas[dim][dim])
{
	int fil;
	int col;
	int linea;

	for (fil = 0; fil < dim; fil++)
	{
		linea = 1;
		for (col = 0; col < dim; col++)
		{
			if (marcadas[col][fil] == 0)
			{
				linea = 0;
			}
		}
		if (linea == 1) return 1;
	}

	for (col = 0; col < dim; col++)
	{
		linea = 1;
		for (fil = 0; fil < dim; fil++)
		{
			if (marcadas[col][fil] == 0)
			{
				linea = 0;
			}
		}
		if (linea == 1) return 1;
	}

	linea = 1;
	for (col = 0; col < dim; col++)
	{
		if (marcadas[col][col] == 0)
		{
			linea = 0;
		}
	}
	if (linea == 1) return 1;

	linea = 1;
	for (col = 0; col < dim; col++)
	{
		if (marcadas[col][dim - 1 - col] == 0)
		{
			linea = 0;
		}
	}
	if (linea == 1) return 1;

	return 0;
}

int verificarcartonlleno (int marcadas[dim][dim])
{
	int fil;
	int col;

	for (col = 0; col < dim; col++)
	{
		for (fil = 0; fil < dim; fil++)
		{
			if (marcadas[col][fil] == 0)
			{
				return 0;
			}
		}
	}

	return 1;
}

void mostrarstats (int ganadas, int perdidas, int apuesta)
{
	colordefault();
	gotoxy(3,7);
	printf("Ganadas: %-5d", ganadas);
	gotoxy(3,8);
	printf("Perdidas: %-4d", perdidas);
	gotoxy(3,9);
	printf("Apuesta actual: %-5d", apuesta);
}

void mostrarbola (int bola)
{
	int grupo;
	int color;

	if (bola == 0)
	{
		setcolor(BLACK, BLACK);
		gotoxy(POS_BOLAX, POS_BOLAY);
		printf("      ");
		gotoxy(POS_BOLAX - 1, POS_BOLAY + 1);
		printf("        ");
		gotoxy(POS_BOLAX - 2, POS_BOLAY + 2);
		printf("          ");
		gotoxy(POS_BOLAX - 1, POS_BOLAY + 3);
		printf("        ");
		gotoxy(POS_BOLAX, POS_BOLAY + 4);
		printf("      ");
		colordefault();
		return;
	}

	grupo = (((bola - 1) / 15) + 1);

	color = randrange(1,4);
	if (color == 1) setcolor(CT, CCSF);
	if (color == 2) setcolor(CMT, CMF);
	if (color == 3) setcolor(CF, colortext);
	if (color == 4) setcolor(colortext, CF);

	gotoxy(POS_BOLAX, POS_BOLAY);
	printf("      ");
	gotoxy(POS_BOLAX - 1, POS_BOLAY + 1);
	printf("        ");
	gotoxy(POS_BOLAX - 2, POS_BOLAY + 2);
	printf("          ");
	gotoxy(POS_BOLAX - 1, POS_BOLAY + 3);
	printf("        ");
	gotoxy(POS_BOLAX, POS_BOLAY + 4);
	printf("      ");

	gotoxy(POS_BOLAX + BOLA_TEXTO_DX, POS_BOLAY + BOLA_TEXTO_DY);
	if (grupo == B) printf("B-%2d", bola);
	if (grupo == I) printf("I-%2d", bola);
	if (grupo == N) printf("N-%2d", bola);
	if (grupo == G) printf("G-%2d", bola);
	if (grupo == O) printf("O-%2d", bola);
}


 
