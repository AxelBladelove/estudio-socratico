		for (col = 0; col < dim; col++)
		{
			if (marcadas[col][fil] == 0)
			{
				linea = 0;
			}
		}
		if (linea == 1) return 1;
	}

	for (col = 0; col < dim; col++)
	{
		linea = 1;
		for (fil = 0; fil < dim; fil++)
		{
			if (marcadas[col][fil] == 0)
			{
				linea = 0;
			}
		}
		if (linea == 1) return 1;
	}

	linea = 1;
	for (col = 0; col < dim; col++)
	{
		if (marcadas[col][col] == 0)
		{
			linea = 0;
		}
	}
	if (linea == 1) return 1;

	linea = 1;
	for (col = 0; col < dim; col++)
	{
		if (marcadas[col][dim - 1 - col] == 0)
		{
			linea = 0;
		}
	}
	if (linea == 1) return 1;

	return 0;
}

