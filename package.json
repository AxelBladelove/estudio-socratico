{
  "name": "estudio-socratico",
  "version": "4.1.0",
  "private": true,
  "description": "Sistema de estudio socratico para Fundamentos de Programacion en C.",
  "scripts": {
    "setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./setup_laptop.ps1",
