{
  "name": "estudio-socratico",
  "version": "2.0.0",
  "private": true,
  "description": "Sistema de estudio socratico para Fundamentos de Programacion en C.",
  "scripts": {
    "installer:restore": "dotnet restore _estudio/installer/EstudioSocratico.Installer.sln",
    "installer:build": "dotnet build _estudio/installer/EstudioSocratico.Installer.sln --configuration Release",
    "installer:test": "dotnet test _estudio/installer/src/EstudioSocratico.Configurator.Tests/EstudioSocratico.Configurator.Tests.csproj --configuration Release",
    "check": "npm run installer:test",
    "drive:auth": "node _estudio/soporte/drive/sync-drive.mjs auth",
    "drive:check": "node _estudio/soporte/drive/sync-drive.mjs check",
    "drive:sync": "node _estudio/soporte/drive/sync-drive.mjs sync",
    "drive:generate": "node _estudio/soporte/drive/sync-drive.mjs generate",
    "drive:generate:alejandro": "node _estudio/soporte/drive/sync-drive.mjs generate --provider alejandro --allow-fallback",
    "drive:sync:alejandro": "node _estudio/soporte/drive/sync-drive.mjs sync --provider alejandro --allow-fallback",
    "exercism:catalog": "powershell -NoProfile -ExecutionPolicy Bypass -File _estudio\\soporte\\exercism\\manager.ps1 -Action catalog",
    "exercism:status": "powershell -NoProfile -ExecutionPolicy Bypass -File _estudio\\soporte\\exercism\\manager.ps1 -Action status",
    "alejandro:gists:publish": "node _estudio/soporte/gists/publish-alejandro-gists.mjs",
    "alejandro:gists:manifest": "node _estudio/soporte/gists/inject-alejandro-manifest.mjs",
    "alejandro:semantic": "node _estudio/soporte/alejandro/semantic-curate-alejandro.mjs",
    "alejandro:icons": "node _estudio/soporte/alejandro/iconify-icons.mjs",
    "alejandro:semantic:report": "node _estudio/soporte/alejandro/report-filter-distribution.mjs",
    "alejandro:semantic:apply": "node _estudio/soporte/alejandro/apply-semantic-results.mjs"
  }
}
