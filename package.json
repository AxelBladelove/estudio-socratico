{
  "name": "estudio-socratico",
  "version": "1.2.0",
  "private": true,
  "description": "Sistema de estudio socratico para Fundamentos de Programacion en C.",
  "scripts": {
    "setup": "setup\\instalar.cmd",
    "setup:update": "setup\\instalar.cmd -Actualizar",
    "setup:dry": "setup\\instalar.cmd -SoloVerificar",
    "check": "setup\\instalar.cmd /sin-pausa -SoloVerificar -SinWinget -SinExtensiones",
    "drive:auth": "node soporte\\drive\\sync-drive.mjs auth",
    "drive:check": "node soporte\\drive\\sync-drive.mjs check",
    "drive:sync": "node soporte\\drive\\sync-drive.mjs sync",
    "drive:generate": "node soporte\\drive\\sync-drive.mjs generate",
    "drive:generate:alejandro": "node soporte\\drive\\sync-drive.mjs generate --provider alejandro --allow-fallback",
    "drive:sync:alejandro": "node soporte\\drive\\sync-drive.mjs sync --provider alejandro --allow-fallback",
    "exercism:catalog": "powershell -NoProfile -ExecutionPolicy Bypass -File soporte\\exercism\\manager.ps1 -Action catalog",
    "exercism:status": "powershell -NoProfile -ExecutionPolicy Bypass -File soporte\\exercism\\manager.ps1 -Action status",
    "alejandro:gists:publish": "node soporte/gists/publish-alejandro-gists.mjs",
    "alejandro:gists:manifest": "node soporte/gists/inject-alejandro-manifest.mjs",
    "alejandro:semantic": "node soporte/alejandro/semantic-curate-alejandro.mjs",
    "alejandro:icons": "node soporte/alejandro/iconify-icons.mjs",
    "alejandro:semantic:report": "node soporte/alejandro/report-filter-distribution.mjs",
    "alejandro:semantic:apply": "node soporte/alejandro/apply-semantic-results.mjs"
  }
}
