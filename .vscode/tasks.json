{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar y Grabar (Sistema Socratico)",
      "type": "shell",
      "command": ".\\build.cmd",
      "args": [
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": {
        "owner": "c",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      },
      "detail": "Compila el archivo .c activo con un wrapper tolerante a Live Share, registra telemetria en usuarios/<usuario>/... y hace un commit automatico etiquetado por usuario."
    },
    {
      "label": "Ejecutar Binario",
      "type": "shell",
      "command": ".\\_output.exe",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "detail": "Ejecuta el ultimo binario compilado sin recompilar."
    },
    {
      "label": "Compilar y Grabar (Live Share Terminal)",
      "type": "shell",
      "command": ".\\build.cmd",
      "args": [
        "--inline",
        "${file}"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": {
        "owner": "c",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      },
      "detail": "Compila el archivo .c activo, registra telemetria y ejecuta el programa dentro de la terminal compartida para Live Share."
    }
  ]
}
